# Twitter API v2 credentials (OAuth 1.1a User Context)
# Get these from: https://developer.twitter.com/en/portal/dashboard
TWITTER_CONSUMER_KEY=your_consumer_key
TWITTER_CONSUMER_SECRET=your_consumer_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# Your bot's Twitter user ID (numeric string)
# Find it at: https://tweeterid.com/
TWITTER_USER_ID=1234567890

# Affiliate tags (optional — bot works without them, just returns plain URLs)
# Amazon Associates tag (e.g., "yourstore-20")
AMAZON_AFFILIATE_TAG=
# Walmart affiliate ID (from Impact Radius or Walmart Affiliate program)
WALMART_AFFILIATE_ID=
# eBay campaign ID (from eBay Partner Network)
EBAY_CAMPAIGN_ID=
# Best Buy affiliate ID (from Impact Radius)
BESTBUY_AFFILIATE_ID=

# Logging
LOG_LEVEL=INFO
